# docker-compose.override.yml.example
# 
# Copy this file to docker-compose.override.yml for local production customizations
# docker-compose.override.yml is git-ignored and will be automatically loaded by Docker Compose
#
# Example customizations:

version: '3.8'

services:
  # Example: Expose backend port for debugging
  # backend:
  #   ports:
  #     - "3001:3001"

  # Example: Expose database port for local tools
  # db:
  #   ports:
  #     - "5432:5432"

  # Example: Custom nginx ports
  # nginx:
  #   ports:
  #     - "8080:80"
  #     - "8443:443"

  # Example: Enable Umami web interface
  # umami:
  #   ports:
  #     - "3000:3000"

  # Example: Allow an external Umami analytics instance in the CSP.
  # Set ANALYTICS_ORIGIN to the full origin (scheme + host) of your Umami
  # server so the dynamically-injected script.js and its beacon requests
  # are not blocked. Must match the URL configured in
  # /admin/settings?tab=analytics.
  #
  # Non-Docker installs (LXC, bare-metal):
  #   - SERVE_FRONTEND=true: set ANALYTICS_ORIGIN in the backend .env — the
  #     Node.js process reads it and injects it into the helmet CSP.
  #   - Separate system nginx: edit the CSP script-src and connect-src lines
  #     in your nginx config manually; see frontend/nginx.conf for the comment.
  # frontend:
  #   environment:
  #     - ANALYTICS_ORIGIN=https://analytics.example.com
  # backend:
  #   environment:
  #     - ANALYTICS_ORIGIN=https://analytics.example.com

  # Example: Use different storage paths
  # backend:
  #   volumes:
  #     - /mnt/photos:/app/storage
  #     - /mnt/data:/app/data

  # Example: Development-like setup with code mounting
  # backend:
  #   volumes:
  #     - ./backend:/app
  #     - /app/node_modules
  #   command: npm run dev

  # Example: Add Mailhog for email testing
  # mailhog:
  #   image: mailhog/mailhog:latest
  #   ports:
  #     - "1025:1025"
  #     - "8025:8025"
  #   restart: unless-stopped